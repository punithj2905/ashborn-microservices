            "projectName": "config-server"
        },
        {
            "type": "java",
            "name": "CustomerApplication",
            "request": "launch",
            "mainClass": "com.ashborn.ecommerce.CustomerApplication",
            "projectName": "customer"
        },
        {
            "type": "java",
            "name": "DiscoveryApplication",
            "request": "launch",
            "mainClass": "com.ashborn.discovery.DiscoveryApplication",
            "projectName": "discovery"
        },
        {
            "type": "java",
            "name": "ProductApplication",
            "request": "launch",
            "mainClass": "com.ashborn.ecommerce.ProductApplication",
            "vmArgs": "-Duser.timezone=Asia/Kolkata",
            "projectName": "product"
        }
    ]
